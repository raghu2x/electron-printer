  },
  "license": "MIT",
  "author": {
    "name": "Raghvendra Yadav",
    "email": "raghvendraa.dev@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/raghu2x/electron-printer.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
