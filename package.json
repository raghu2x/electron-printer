    "jsbarcode": "^3.12.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "@types/qrcode": "^1.5.6",
    "bundle-declarations-webpack-plugin": "^6.0.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^7.0.4",
    "electron": "^40.4.1",
    "html-webpack-plugin": "^5.6.6",
    "mini-css-extract-plugin": "^2.10.0",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "playwright": "^1.58.2",
    "terser-webpack-plugin": "^5.3.16",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.2",
