{
  "name": "@devraghu/electron-printer",
  "version": "2.3.0",
  "private": false,
  "description": "Electron printer plugin for 80mm, 78mm, 76mm, 58mm, 57mm, 44mm printers",
  "keywords": [
    "electron",
    "pos",
    "printer",
    "thermal"
  ],
  "homepage": "https://github.com/raghu2x/electron-printer#readme",
  "bugs": {
    "url": "https://github.com/raghu2x/electron-printer/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Raghvendra Yadav",
    "email": "raghvendraa.dev@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/raghu2x/electron-printer.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "playwright test",
    "demo": "electron ./demo/",
    "build": "electron-vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "clean": "git clean -fx ./dist",
    "prebuild": "bun run clean",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@devraghu/cashdrawer": "^0.3.2",
    "dompurify": "^3.4.5",
    "jsbarcode": "^3.12.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@microsoft/api-extractor": "^7.58.7",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "electron": "^42.2.0",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "playwright": "^1.60.0",
    "typescript": "6.0.3",
    "unplugin-dts": "^1.0.1",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "electron": ">=30.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": "^24 || ^22 || ^20"
  },
  "packageManager": "bun@1.3.14"
}
