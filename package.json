{
  "name": "@devraghu/electron-printer",
  "version": "2.0.0",
  "private": false,
  "description": "Electron printer plugin for 80mm, 78mm, 76mm, 58mm, 57mm, 44mm printers",
  "keywords": [
    "electron",
    "pos",
    "printer",
    "thermal"
  ],
  "homepage": "https://github.com/raghu2x/electron-printer#readme",
  "bugs": {
    "url": "https://github.com/raghu2x/electron-printer/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Raghvendra Yadav",
    "email": "raghvendraa.dev@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/raghu2x/electron-printer.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "playwright test",
    "demo": "electron ./demo/",
    "build": "electron-vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "clean": "git clean -fx ./dist",
    "prebuild": "npm run clean",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@devraghu/cashdrawer": "^0.3.0",
    "dompurify": "^3.3.1",
    "jsbarcode": "^3.12.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.2",
    "@types/qrcode": "^1.5.6",
    "electron": "^40.6.1",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "electron": ">=30.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "engines": {
    "node": "^24 || ^22 || ^20",
    "npm": ">= 9.0.0",
    "yarn": ">= 1.21.1"
  }
}
